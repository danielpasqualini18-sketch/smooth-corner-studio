---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta
			name="description"
			content="Photography by Smooth Corner Studio. Honest, tactile brand, lifestyle and event photography by Daniel Pasqualini."
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Photography | Smooth Corner Studio</title>
	</head>

	<body>
		<header class="page-header">
			<a class="back-link" href="/#work">Back to Smooth Corner Studio</a>
		</header>

		<main>
			<section class="project-hero">
				<div class="project-shell">
					<p class="eyebrow">Photography</p>
					<h1 class="display-title">Photography with texture and feeling.</h1>
					<p class="hero-copy">
						I like photographs that feel honest, warm and a little tactile. Images that still feel
						alive after the moment has passed, whether they are made for a brand, an event, a place,
						a person or a small story worth remembering.
					</p>
				</div>
			</section>

			<section class="project-section">
				<div class="project-shell story-grid">
					<h2 class="display-title">Images that feel alive.</h2>

					<div class="text-stack">
						<p>
							Photography is often the fastest way to make something feel real. A face, a place, a
							detail, a bit of light, a quiet in-between moment. That is usually where the good
							stuff is.
						</p>

						<p>
							My approach is considered, but never too stiff. I am drawn to natural light, texture,
							old cameras, film grain, handmade details and people who look like themselves. The
							work can be polished when it needs to be, but I always want it to keep a bit of
							warmth.
						</p>

						<p>
							That might mean brand imagery, lifestyle work, portraits, event coverage, editorial
							photography or a set of images that simply helps a project feel more human. The goal
							is to make photographs that are useful, beautiful and full of character.
						</p>
					</div>
				</div>
			</section>

			<section class="project-section gallery-section">
				<div class="project-shell">
					<div class="section-heading">
						<p class="eyebrow">Selected photography</p>
						<h2 class="display-title">A few frames.</h2>
					</div>

					<div class="photo-grid" id="photography-gallery">
						<figure class="photo-card tall">
							<a href="/images/title-background.jpg" target="_blank" rel="noreferrer">
								<img src="/images/title-background.jpg" alt="Brand image placeholder one" />
							</a>
						</figure>

						<figure class="photo-card tall">
							<a href="/images/portrait-test.jpg" target="_blank" rel="noreferrer">
								<img src="/images/portrait-test.jpg" alt="Portrait image placeholder" />
							</a>
						</figure>

						<figure class="photo-card wide">
							<a href="/images/title-background.jpg" target="_blank" rel="noreferrer">
								<img src="/images/title-background.jpg" alt="Brand image placeholder three" />
							</a>
						</figure>

						<figure class="photo-card">
							<a href="/images/services-background.jpg" target="_blank" rel="noreferrer">
								<img src="/images/services-background.jpg" alt="Lifestyle image placeholder four" />
							</a>
						</figure>

						<figure class="photo-card tall">
							<a href="/images/title-background.jpg" target="_blank" rel="noreferrer">
								<img src="/images/title-background.jpg" alt="Brand image placeholder five" />
							</a>
						</figure>

						<figure class="photo-card">
							<a href="/images/services-background.jpg" target="_blank" rel="noreferrer">
								<img src="/images/services-background.jpg" alt="Lifestyle image placeholder six" />
							</a>
						</figure>

						<figure class="photo-card wide">
							<a href="/images/title-background.jpg" target="_blank" rel="noreferrer">
								<img src="/images/title-background.jpg" alt="Brand image placeholder seven" />
							</a>
						</figure>

						<figure class="photo-card">
							<a href="/images/services-background.jpg" target="_blank" rel="noreferrer">
								<img
									src="/images/services-background.jpg"
									alt="Lifestyle image placeholder eight"
								/>
							</a>
						</figure>

						<figure class="photo-card tall">
							<a href="/images/title-background.jpg" target="_blank" rel="noreferrer">
								<img src="/images/title-background.jpg" alt="Brand image placeholder nine" />
							</a>
						</figure>
					</div>
				</div>
			</section>

			<section class="project-section cta-section">
				<div class="project-shell cta-card">
					<p class="eyebrow">Need a set of images?</p>
					<h2 class="display-title">Let’s make it feel real.</h2>
					<p class="cta-copy">
						Tell me what you are making, who it is for and what kind of feeling the images need to carry.
					</p>
					<a class="button primary" href="/#contact">Start a conversation</a>
				</div>
			</section>
		</main>

		<script>
			import PhotoSwipeLightbox from "photoswipe/lightbox";
			import "photoswipe/style.css";

			const galleryLinks = document.querySelectorAll("#photography-gallery a");

			const setPhotoSwipeDimensions = (link) => {
				const thumbnail = link.querySelector("img");
				if (!thumbnail || thumbnail.naturalWidth === 0 || thumbnail.naturalHeight === 0) return;

				link.dataset.pswpWidth = String(thumbnail.naturalWidth);
				link.dataset.pswpHeight = String(thumbnail.naturalHeight);
			};

			galleryLinks.forEach((link) => {
				const thumbnail = link.querySelector("img");

				if (thumbnail?.complete) {
					setPhotoSwipeDimensions(link);
				} else {
					thumbnail?.addEventListener("load", () => setPhotoSwipeDimensions(link), { once: true });
				}
			});

			const lightbox = new PhotoSwipeLightbox({
				gallery: "#photography-gallery",
				children: "a",
				pswpModule: () => import("photoswipe"),
				paddingFn: (viewportSize) => {
					const isMobile = viewportSize.x < 850;

					return {
						top: isMobile ? 72 : 96,
						bottom: isMobile ? 72 : 96,
						left: isMobile ? 22 : 72,
						right: isMobile ? 22 : 72,
					};
				},
			});

			lightbox.on("itemData", (event) => {
				const link = event.itemData.element;

				if (!link?.dataset.pswpWidth || !link?.dataset.pswpHeight) {
					setPhotoSwipeDimensions(link);
				}
			});

			lightbox.init();
		</script>
	</body>
</html>

<style>
	body {
		background: var(--ink);
		color: var(--cream);
	}

	.page-header {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 10;
		width: 100%;
		display: flex;
		justify-content: center;
		padding: 22px clamp(20px, 4vw, 48px);
		background: rgba(28, 28, 27, 0.42);
		border-bottom: 1px solid rgba(244, 234, 220, 0.18);
		border-radius: 0 0 68px 68px;
		backdrop-filter: blur(8px);
	}

	.back-link {
		color: var(--sand);
		font-size: 0.84rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.project-shell {
		width: min(100% - 40px, 1180px);
		margin: 0 auto;
	}

	.project-hero {
		position: relative;
		isolation: isolate;
		min-height: 86vh;
		display: grid;
		align-content: center;
		padding: 180px 0 96px;
		overflow: hidden;
		border-radius: 0 0 68px 68px;
		background:
			linear-gradient(
				90deg,
				rgba(28, 28, 27, 0.9),
				rgba(28, 28, 27, 0.56) 52%,
				rgba(28, 28, 27, 0.28)
			),
			url("/images/title-background.jpg") center center / cover no-repeat;
	}

	.project-hero .eyebrow,
	.section-heading .eyebrow,
	.cta-card .eyebrow {
		font-size: clamp(0.9rem, 1.2vw, 1.05rem);
	}

	.project-hero h1 {
		max-width: 1080px;
		margin: 0;
		color: var(--sand);
		font-size: clamp(4rem, 10vw, 10rem);
		letter-spacing: 0.015em;
		line-height: 0.88;
		padding-left: 0.04em;
		text-shadow: 0 8px 32px rgba(0, 0, 0, 0.34);
	}

	.hero-copy {
		max-width: 680px;
		margin: 32px 0 0;
		color: rgba(244, 234, 220, 0.9);
		font-size: clamp(1.05rem, 1.7vw, 1.35rem);
		line-height: 1.55;
	}

	.project-section {
		padding: clamp(72px, 10vw, 130px) 0;
	}

	.story-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
		gap: clamp(32px, 8vw, 100px);
		align-items: start;
	}

	.story-grid h2,
	.section-heading h2,
	.cta-card h2 {
		margin: 0;
		color: var(--cream);
		font-size: clamp(3rem, 7vw, 7.5rem);
		letter-spacing: 0.015em;
		line-height: 0.9;
		padding-left: 0.04em;
	}

	.text-stack {
		display: grid;
		gap: 22px;
	}

	.text-stack p,
	.cta-card p {
		margin: 0;
		color: rgba(244, 234, 220, 0.78);
		font-size: 1.04rem;
		line-height: 1.7;
	}

	.gallery-section {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		border-radius: 68px;
		background:
			linear-gradient(rgba(28, 28, 27, 0.5), rgba(28, 28, 27, 0.5)),
			url("/images/services-background.jpg") center / cover no-repeat;
	}

	.section-heading {
		display: grid;
		gap: 14px;
		margin-bottom: clamp(34px, 5vw, 58px);
	}

	.photo-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		grid-auto-rows: 150px;
		gap: 18px;
	}

	.photo-card a {
		display: block;
		width: 100%;
		height: 100%;
	}

	.photo-card a:focus-visible {
		outline: 2px solid var(--sand);
		outline-offset: 4px;
	}

	.photo-card {
		grid-column: span 2;
		grid-row: span 2;
		margin: 0;
		min-height: 100%;
		border: 1px solid rgba(244, 234, 220, 0.18);
		border-radius: 28px;
		background: rgba(28, 28, 27, 0.42);
		backdrop-filter: blur(8px);
		overflow: hidden;
	}

	.photo-card img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		transition:
			transform 220ms ease,
			opacity 220ms ease;
	}

	.photo-card:hover img {
		transform: scale(1.025);
		opacity: 0.92;
	}

	:global(.pswp__img) {
		border-radius: 24px;
	}

	:global(.pswp__img--placeholder) {
		border-radius: 24px;
	}

	:global(.pswp__bg) {
		background: rgba(28, 28, 27, 0.92);
	}

	.photo-card.wide {
		grid-column: span 4;
	}

	.photo-card.tall {
		grid-row: span 3;
	}

	.photo-placeholder {
		width: 100%;
		height: 100%;
		display: grid;
		place-items: center;
		background:
			radial-gradient(circle at top right, rgba(215, 174, 129, 0.18), transparent 16rem),
			rgba(244, 234, 220, 0.05);
		color: var(--sand);
		font-size: 0.82rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		text-align: center;
	}

	.cta-card {
		display: grid;
		gap: 22px;
		padding: clamp(32px, 6vw, 64px);
		border: 1px solid rgba(244, 234, 220, 0.18);
		border-radius: 42px;
		background:
			radial-gradient(circle at top right, rgba(215, 174, 129, 0.18), transparent 18rem),
			rgba(244, 234, 220, 0.04);
	}

	.cta-card p {
		max-width: 640px;
	}

	.cta-card .cta-copy {
		max-width: none;
		white-space: nowrap;
	}

	.cta-card .button {
		width: fit-content;
		margin-top: 20px;
	}

	:global(.pswp) {
		--pswp-icon-color: var(--sand);
		--pswp-icon-color-secondary: rgba(28, 28, 27, 0.72);
		--pswp-bg: rgba(28, 28, 27, 0.92);
	}

	:global(.pswp__button) {
		color: var(--sand) !important;
		opacity: 0.92;
	}

	:global(.pswp__button:hover) {
		color: var(--cream) !important;
		opacity: 1;
	}

	:global(.pswp__counter) {
		color: var(--sand) !important;
		opacity: 0.78;
	}

	:global(.pswp__button svg),
	:global(.pswp__icn) {
		color: var(--sand) !important;
		fill: var(--sand) !important;
		stroke: var(--sand) !important;
	}

	:global(.pswp__button:hover svg),
	:global(.pswp__button:hover .pswp__icn) {
		color: var(--cream) !important;
		fill: var(--cream) !important;
		stroke: var(--cream) !important;
	}

	@media (max-width: 850px) {
		.page-header {
			padding: 14px 16px;
			border-radius: 0 0 48px 48px;
		}

		.project-hero {
			min-height: auto;
			padding: 170px 0 72px;
			border-radius: 0 0 48px 48px;
		}

		.project-hero h1 {
			font-size: clamp(3.5rem, 18vw, 6.8rem);
		}

		.story-grid {
			grid-template-columns: 1fr;
		}

		.gallery-section {
			border-radius: 48px;
		}

		.photo-grid {
			grid-template-columns: 1fr;
			grid-auto-rows: auto;
		}

		.photo-card,
		.photo-card.wide,
		.photo-card.tall {
			grid-column: auto;
			grid-row: auto;
		}

		.photo-placeholder {
			aspect-ratio: 4 / 5;
			height: auto;
		}

		.cta-card .cta-copy {
			white-space: normal;
		}
	}
</style>
