---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Smooth Corner Studio by Daniel Pasqualini is coming soon." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smooth Corner Studio | Coming Soon</title>

    <style>
      :root {
        --bg: #111111;
        --text: #f4f1ea;
        --muted: #b8b1a6;
        --line: rgba(244, 241, 234, 0.18);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        display: grid;
        place-items: center;
        padding: 24px;
      }

      main {
        width: 100%;
        max-width: 820px;
      }

      .eyebrow {
        font-size: 0.78rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 32px;
      }

      h1 {
        font-size: clamp(3rem, 10vw, 7.5rem);
        line-height: 0.9;
        letter-spacing: -0.07em;
        margin: 0;
        max-width: 780px;
      }

      .subline {
        margin-top: 32px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: grid;
        gap: 18px;
        max-width: 620px;
      }

      p {
        margin: 0;
        font-size: clamp(1.05rem, 2vw, 1.35rem);
        line-height: 1.55;
        color: var(--muted);
      }

      a {
        color: var(--text);
        text-decoration: none;
        border-bottom: 1px solid var(--text);
      }

      a:hover {
        color: var(--muted);
        border-color: var(--muted);
      }

      .footer {
        margin-top: 64px;
        font-size: 0.9rem;
        color: var(--muted);
      }
    </style>
  </head>

  <body>
    <main>
      <div class="eyebrow">Smooth Corner Studio by Daniel Pasqualini</div>

      <h1>New site coming soon.</h1>

      <section class="subline">
        <p>
          Photography, filmmaking and visual storytelling from Perth, Western Australia.
        </p>

        <p>
          For enquiries, contact
          <a href="mailto:daniel@smoothcornerstudio.com.au">daniel@smoothcornerstudio.com.au</a>
        </p>
      </section>

      <div class="footer">
        © 2026 Smooth Corner Studio
      </div>
    </main>
  </body>
</html>
