---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta
			name="description"
			content="Smooth Corner Studio by Daniel Pasqualini. Photography, films and visual stories from Perth, Western Australia."
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Smooth Corner Studio by Daniel Pasqualini</title>
	</head>

	<body>
		<header class="site-header">
			<nav class="site-nav" aria-label="Main navigation">
				<a href="#work">Work</a>
				<a href="#about">About</a>
				<a href="#services">Services</a>
				<a href="#contact">Contact</a>
			</nav>

			<a href="/" class="brand-logo" aria-label="Smooth Corner Studio home">
				<span class="logo-bloom" aria-hidden="true"></span>
				<img src="/images/brand/smooth-corner-logo-extended.png" alt="Smooth Corner Studio" />
			</a>
		</header>

		<main>
			<section class="hero site-shell">
				<p class="eyebrow">Boorloo / Perth, Western Australia</p>

				<h1 class="display-title">
					Quiet images.<br />
					Honest films.
				</h1>

				<div class="hero-intro">
					<p>
						I’m Daniel. Smooth Corner Studio is my creative practice: films, photography and visual
						stories for people, places and projects with character.
					</p>

					<div class="button-row">
						<a class="button primary" href="#work">View my work</a>
						<a class="button" href="#contact">Start a conversation</a>
					</div>
				</div>
			</section>

			<section id="work" class="section">
				<div class="site-shell">
					<div class="section-heading">
						<p class="eyebrow">Selected work</p>
						<h2 class="display-title">Stories, people, atmosphere.</h2>
					</div>

					<div class="work-grid">
						<a class="work-card feature-card" href="/films-stories" aria-label="View films and visual stories work">
							<div class="image-placeholder image-cover">
								<img src="/images/films-cover.jpg" alt="Films and visual stories portfolio preview" />
							</div>
							<div class="card-content">
								<p class="card-meta">Films and visual stories</p>
								<h3>Thoughtful films with a human eye</h3>
								<p>
									Films shaped around people, atmosphere, rhythm and real moments, for projects with
									something honest to say.
								</p>
							</div>
						</a>

						<a class="work-card" href="/photography" aria-label="View photography work">
							<div class="image-placeholder warm image-cover">
								<img src="/images/photography-cover.jpg" alt="Photography portfolio preview" />
							</div>
							<div class="card-content">
								<p class="card-meta">Photography</p>
								<h3>Photography with texture and feeling</h3>
								<p>
									Brand, lifestyle and portrait images that feel honest, tactile and alive, with a
									bit of warmth and character.
								</p>
							</div>
						</a>

						<a class="work-card" href="/events" aria-label="View people and real life coverage">
							<div class="image-placeholder blue image-cover">
								<img src="/images/events-cover.jpg" alt="People gathered at an event" />
							</div>
							<div class="card-content">
								<p class="card-meta">Event coverage</p>
								<h3>People, gathered and alive</h3>
								<p>
									Weddings, engagements, family moments, gatherings and events photographed with a
									calm eye for real life as it happens.
								</p>
							</div>
						</a>
					</div>
				</div>
			</section>

			<section id="about" class="section">
				<div class="site-shell about-layout">
					<p class="eyebrow">About</p>

					<div class="about-grid">
						<h2 class="display-title">A small studio with a human eye.</h2>

						<div class="text-stack">
							<p>
								Smooth Corner Studio is my way of bringing together the things I care about most:
								honest images, thoughtful films, tactile details and stories that feel alive.
							</p>

							<p>
								I’m drawn to natural light, real people, imperfect moments, old cameras, film grain,
								handmade things and places with character. I like work that feels considered, but
								not too polished. Planned, but not stiff. Beautiful, but still human.
							</p>

							<p>
								The studio brings together photography, filmmaking, editing, creative direction and
								production planning, from small intimate shoots to larger projects with a bit more
								shape and intention. The goal is always the same: to make something warm, honest
								and useful, with texture, care and a clear sense of place.
							</p>
						</div>
					</div>
				</div>
			</section>

			<section id="services" class="section section-line services-section">
				<div class="site-shell">
					<div class="section-heading">
						<p class="eyebrow">Services</p>
						<h2 class="display-title">What I can help with.</h2>
					</div>

					<div class="services-grid">
						<article>
							<h3>Photography</h3>
							<p>
								Portraits, events, places and brand imagery with a natural, tactile feel. Honest
								images for people and projects that need to feel warm, useful and alive.
							</p>
						</article>

						<article>
							<h3>Films and visual stories</h3>
							<p>
								Small films, social pieces and story-led video for projects with something real to
								say. Built around people, atmosphere, rhythm and moments that do not feel too
								polished.
							</p>
						</article>

						<article>
							<h3>Creative production</h3>
							<p>
								Planning, creative direction, editing and production support to help shape the idea
								before the shoot, not just make it look good at the end.
							</p>
						</article>
					</div>
				</div>
			</section>

			<section id="contact" class="section contact-section">
				<div class="site-shell contact-card">
					<div class="contact-copy">
						<p class="eyebrow">Contact</p>
						<h2 class="display-title">Have a story, project or idea?</h2>
						<p>
							Tell me a little about what you’re making, where it needs to live and what kind of
							feeling you want it to carry. I’m available for photography, films and visual story
							projects across Boorloo / Perth, regional Western Australia and beyond.
						</p>
					</div>

					<form
						id="contact-form"
						class="request-form"
						action="https://formspree.io/f/xeedpnpj"
						method="POST"
					>
						<input
							type="hidden"
							name="_subject"
							value="New project enquiry from Smooth Corner Studio"
						/>
						<div class="form-field">
							<label for="name">Name</label>
							<input id="name" name="Name" type="text" autocomplete="name" required />
						</div>

						<div class="form-field">
							<label for="email">Email</label>
							<input id="email" name="email" type="email" autocomplete="email" required />
						</div>

						<div class="form-field">
							<label for="project-type">Project type</label>
							<select id="project-type" name="Project type" required>
								<option value="">Choose one</option>
								<option value="Story-led film">Story-led film</option>
								<option value="Photography">Photography</option>
								<option value="Event coverage">Event coverage</option>
								<option value="Creative direction">Creative direction</option>
								<option value="Something else">Something else</option>
							</select>
						</div>

						<div class="form-field">
							<label for="timeline">Timeline</label>
							<input
								id="timeline"
								name="Timeline"
								type="text"
								placeholder="Rough date or timeframe"
							/>
						</div>

						<div class="form-field full-width">
							<label for="message">Project notes</label>
							<textarea
								id="message"
								name="Project notes"
								rows="6"
								placeholder="Tell me about the story, people, place, mood or outcome you have in mind."
								required></textarea>
						</div>

						<button class="button primary form-submit" type="submit">Send enquiry</button>
					</form>

					<div id="form-modal" class="form-modal" aria-hidden="true">
						<div
							class="form-modal-card"
							role="dialog"
							aria-modal="true"
							aria-labelledby="form-modal-title"
						>
							<p class="eyebrow">Enquiry sent</p>
							<h3 id="form-modal-title">Thanks, I got your enquiry.</h3>
							<p>I’ll have a proper look and get back to you soon.</p>
							<button id="form-modal-close" class="button primary" type="button">OK</button>
						</div>
					</div>
				</div>
			</section>
		</main>

		<footer class="site-footer">
			<div class="footer-overlay">
				<div class="site-shell footer-grid">
					<div class="footer-logo">
						<img
							src="/images/brand/smooth-corner-logo-badge-white.png"
							alt="Smooth Corner Studio"
						/>
					</div>

					<div class="footer-acknowledgement">
						<p>
							Smooth Corner Studio acknowledges the Whadjuk people of the Noongar nation as the
							Traditional Custodians of Boorloo and the Derbarl Yerrigan, the land and waters on
							which we live and work. We pay our respects to Elders past and present, and recognise
							their continuing connection to culture, community, land and waters.
						</p>

						<p>
							We extend that respect to all Aboriginal and Torres Strait Islander people, and
							acknowledge the care, knowledge and stories that continue to shape this place we are
							lucky to call home.
						</p>
					</div>

					<div class="footer-contact">
						<p class="eyebrow">Contact</p>

						<a href="mailto:hello@smoothcornerstudio.com.au"> Email </a>

						<a
							href="https://www.instagram.com/danielpasqualini_/"
							target="_blank"
							rel="noopener noreferrer"
						>
							Instagram
						</a>
					</div>
				</div>

				<div class="site-shell footer-bottom">
					<p>© 2026 Smooth Corner Studio. Photography and filmmaking by Daniel Pasqualini.</p>
				</div>
			</div>
		</footer>
		<script>
			const contactForm = document.querySelector("#contact-form");
			const formModal = document.querySelector("#form-modal");
			const formModalClose = document.querySelector("#form-modal-close");

			const openFormModal = () => {
				if (!formModal) return;
				formModal.classList.add("visible");
				formModal.setAttribute("aria-hidden", "false");
				formModalClose?.focus();
			};

			const closeFormModal = () => {
				if (!formModal) return;
				formModal.classList.remove("visible");
				formModal.setAttribute("aria-hidden", "true");
			};

			if (contactForm && formModal && formModalClose) {
				contactForm.addEventListener("submit", async (event) => {
					event.preventDefault();

					const submitButton = contactForm.querySelector("button[type='submit']");
					const formData = new FormData(contactForm);

					if (submitButton) {
						submitButton.disabled = true;
					}

					try {
						const response = await fetch(contactForm.action, {
							method: "POST",
							body: formData,
							headers: {
								Accept: "application/json",
							},
						});

						if (response.ok) {
							contactForm.reset();
							openFormModal();
						} else {
							alert(
								"Sorry, something went wrong. Please email hello@smoothcornerstudio.com.au instead.",
							);
						}
					} catch (error) {
						alert(
							"Sorry, something went wrong. Please email hello@smoothcornerstudio.com.au instead.",
						);
					} finally {
						if (submitButton) {
							submitButton.disabled = false;
						}
					}
				});

				formModalClose.addEventListener("click", closeFormModal);

				formModal.addEventListener("click", (event) => {
					if (event.target === formModal) {
						closeFormModal();
					}
				});

				document.addEventListener("keydown", (event) => {
					if (event.key === "Escape") {
						closeFormModal();
					}
				});
			}
		</script>
	</body>
</html>

<style>
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 10;
		width: 100%;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 24px;
		padding: 22px clamp(20px, 4vw, 48px);
		color: var(--cream);
		background: rgba(28, 28, 27, 0.6);
		border-bottom: 1px solid rgba(244, 234, 220, 0.18);
		border-radius: 0 0 68px 68px;
		backdrop-filter: blur(18px);
	}

	section {
		scroll-margin-top: 132px;
	}

	.brand-logo {
		grid-column: 2;
		position: relative;
		display: block;
		width: clamp(280px, 30vw, 425px);
	}

	.logo-bloom {
		display: none;
	}

	.brand-logo img {
		width: 100%;
		height: auto;
	}

	.site-nav {
		grid-column: 1;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: clamp(20px, 3vw, 42px);
		font-size: clamp(1rem, 1.15vw, 1.18rem);
		color: var(--text-soft);
	}

	.site-nav a {
		transition: color 180ms ease;
	}

	.site-nav a:hover {
		color: var(--sand);
	}

	.hero {
		position: relative;
		isolation: isolate;
		width: 100vw;
		max-width: none;
		margin-left: calc(50% - 50vw);
		min-height: 100vh;
		display: grid;
		align-content: center;
		padding: 220px max(clamp(20px, 4vw, 48px), calc((100vw - 1440px) / 2)) 72px;
		overflow: hidden;
		border-radius: 0 0 68px 68px;
		background:
			linear-gradient(
				90deg,
				rgba(38, 29, 24, 0.88),
				rgba(54, 39, 31, 0.52) 48%,
				rgba(72, 48, 34, 0.26)
			),
			url("/images/title-background.jpg") center center / cover no-repeat;
	}


	.hero > * {
		position: relative;
		z-index: 1;
	}

	.hero .eyebrow {
		margin: 0 0 28px;
		font-size: clamp(0.9rem, 1.2vw, 1.05rem);
	}

	.section-heading .eyebrow,
	.two-column .eyebrow {
		font-size: clamp(0.9rem, 1.2vw, 1.05rem);
	}

	.about-layout {
		display: grid;
		gap: 16px;
	}

	.about-layout > .eyebrow {
		margin: 0;
		font-size: clamp(0.9rem, 1.2vw, 1.05rem);
	}

	.about-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
		gap: clamp(32px, 8vw, 100px);
		align-items: start;
	}

	.about-grid h2 {
		margin: 0;
		font-size: clamp(3rem, 7vw, 7.5rem);
		color: var(--cream);
		letter-spacing: 0.015em;
		padding-left: 0.04em;
	}

	.hero h1 {
		max-width: 1100px;
		margin: 0;
		color: var(--sand);
		font-size: clamp(4rem, 9.5vw, 10.8rem);
		letter-spacing: 0.015em;
		padding-left: 0.04em;
		text-shadow: 0 8px 32px rgba(0, 0, 0, 0.34);
	}

	.hero-intro {
		margin-top: 40px;
		display: grid;
		gap: 34px;
		max-width: 720px;
	}

	.hero-intro p {
		margin: 0;
		color: rgba(244, 234, 220, 0.9);
		font-size: clamp(1.05rem, 1.7vw, 1.35rem);
		line-height: 1.55;
	}

	.section-heading {
		display: grid;
		gap: 16px;
		margin-bottom: clamp(32px, 6vw, 72px);
	}

	.section-heading h2,
	.two-column h2,
	.contact-card h2 {
		margin: 0;
		font-size: clamp(3rem, 7vw, 7.5rem);
		color: var(--cream);
		letter-spacing: 0.015em;
		padding-left: 0.04em;
	}

	.work-grid {
		display: grid;
		grid-template-columns: 1.3fr 1fr;
		gap: 20px;
	}

	.work-card {
		display: block;
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 28px;
		background: rgba(244, 234, 220, 0.045);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease;
	}

	.work-card:nth-child(1) {
		background:
			radial-gradient(circle at 18% 92%, rgba(198, 119, 79, 0.18), transparent 20rem),
			radial-gradient(circle at 94% 12%, rgba(215, 174, 129, 0.12), transparent 18rem),
			rgba(244, 234, 220, 0.045);
	}

	.work-card:nth-child(2) {
		background:
			radial-gradient(circle at 8% 18%, rgba(215, 174, 129, 0.17), transparent 18rem),
			radial-gradient(circle at 96% 86%, rgba(122, 138, 133, 0.12), transparent 17rem),
			rgba(244, 234, 220, 0.045);
	}

	.work-card:nth-child(3) {
		background:
			radial-gradient(circle at 92% 78%, rgba(122, 138, 133, 0.17), transparent 18rem),
			radial-gradient(circle at 10% 10%, rgba(60, 71, 97, 0.16), transparent 19rem),
			rgba(244, 234, 220, 0.045);
	}

	a.work-card:hover {
		transform: translateY(-3px);
		border-color: rgba(215, 174, 129, 0.42);
		background-color: rgba(244, 234, 220, 0.065);
	}

	.feature-card {
		grid-row: 1 / span 2;
		align-self: start;
		margin-top: 180px;
	}

	.image-placeholder {
		min-height: 340px;
		display: grid;
		place-items: center;
		background:
			linear-gradient(135deg, rgba(122, 138, 133, 0.35), rgba(60, 71, 97, 0.34)), var(--charcoal);
		color: rgba(244, 234, 220, 0.52);
		font-size: 0.82rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.image-placeholder.warm {
		background:
			linear-gradient(135deg, rgba(181, 83, 63, 0.3), rgba(215, 174, 129, 0.24)), var(--charcoal);
	}

	.image-placeholder.blue {
		background:
			linear-gradient(135deg, rgba(60, 71, 97, 0.42), rgba(122, 138, 133, 0.26)), var(--charcoal);
	}

	.image-cover {
		position: relative;
		overflow: hidden;
	}

	.image-cover img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.feature-card .image-placeholder {
		min-height: 420px;
	}

	.card-content {
		padding: 24px;
	}

	.card-meta {
		margin: 0 0 12px;
		color: var(--sand);
		font-size: 1rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.card-content h3,
	.services-grid h3 {
		margin: 0 0 12px;
		color: var(--cream);
		font-size: 1.35rem;
		letter-spacing: 0.015em;
	}

	.card-content p,
	.services-grid p,
	.text-stack p,
	.contact-card p {
		margin: 0;
		color: var(--text-soft);
	}

	.two-column {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
		gap: clamp(32px, 8vw, 100px);
		align-items: start;
	}

	.text-stack {
		display: grid;
		gap: 22px;
		font-size: clamp(1.02rem, 1.5vw, 1.22rem);
	}

	.services-section {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		border-radius: 68px;
	}

	.services-section::before {
		content: "";
		position: absolute;
		inset: 0 calc(50% - 50vw);
		z-index: -2;
		background:
			linear-gradient(rgba(28, 28, 27, 0.5), rgba(28, 28, 27, 0.5)),
			url("/images/services-background.jpg") center / cover no-repeat;
		opacity: 0.9;
	}

	.services-section > .site-shell {
		position: relative;
		z-index: 1;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 18px;
	}

	.services-grid article {
		min-height: 260px;
		display: grid;
		align-content: center;
		padding: 28px;
		border: 1px solid rgba(244, 234, 220, 0.18);
		border-radius: 28px;
		background: rgba(28, 28, 27, 0.42);
		backdrop-filter: blur(8px);
	}

	.services-grid article:nth-child(1) {
		background:
			radial-gradient(circle at 86% 12%, rgba(215, 174, 129, 0.18), transparent 17rem),
			radial-gradient(circle at 10% 90%, rgba(198, 119, 79, 0.12), transparent 18rem),
			rgba(28, 28, 27, 0.42);
	}

	.services-grid article:nth-child(2) {
		background:
			radial-gradient(circle at 14% 18%, rgba(122, 138, 133, 0.16), transparent 17rem),
			radial-gradient(circle at 92% 88%, rgba(60, 71, 97, 0.14), transparent 18rem),
			rgba(28, 28, 27, 0.42);
	}

	.services-grid article:nth-child(3) {
		background:
			radial-gradient(circle at 88% 82%, rgba(198, 119, 79, 0.14), transparent 18rem),
			radial-gradient(circle at 10% 12%, rgba(215, 174, 129, 0.12), transparent 16rem),
			rgba(28, 28, 27, 0.42);
	}

	.contact-section {
		padding-bottom: clamp(48px, 8vw, 96px);
	}

	.contact-card {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1fr);
		gap: clamp(40px, 7vw, 96px);
		align-items: start;
		padding: clamp(32px, 7vw, 82px);
		border: 1px solid var(--line);
		border-radius: 36px;
		background:
			radial-gradient(circle at top right, rgba(215, 174, 129, 0.16), transparent 30rem),
			rgba(244, 234, 220, 0.045);
	}

	.contact-card p {
		max-width: 640px;
		font-size: clamp(1.05rem, 1.6vw, 1.28rem);
	}

	.contact-copy {
		display: grid;
		gap: 22px;
		position: sticky;
		top: 180px;
	}

	.request-form {
		display: grid;
		grid-template-columns: 1fr;
		gap: 18px;
		padding: clamp(22px, 3vw, 34px);
		border: 1px solid rgba(244, 234, 220, 0.14);
		border-radius: 28px;
		background: rgba(28, 28, 27, 0.32);
	}

	.form-field {
		display: grid;
		gap: 8px;
	}

	.form-field label {
		color: var(--sand);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.form-field input,
	.form-field select,
	.form-field textarea {
