---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta
			name="description"
			content="Smooth Corner Studio by Daniel Pasqualini. New website coming soon."
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Smooth Corner Studio | Coming Soon</title>
	</head>

	<body>
		<main class="wip-page">
			<section class="wip-hero">
				<div class="wip-card">
					<div class="logo-wrap">
						<img
							src="/images/brand/smooth-corner-logo-extended.png"
							alt="Smooth Corner Studio"
						/>
					</div>

					<div class="wip-copy">
						<p class="eyebrow">Boorloo / Perth, Western Australia</p>

						<h1 class="display-title">
							Quiet images.<br />
							Honest films.<br />
							Coming soon.
						</h1>

						<p>
							The new Smooth Corner Studio website is currently being shaped, polished and gently overthought.
						</p>

						<p>
							In the meantime, I’m still available for photography, films and visual stories across Boorloo / Perth and beyond.
						</p>
					</div>

					<div class="wip-links">
						<a href="mailto:hello@smoothcornerstudio.com.au">Email</a>
						<a
							href="https://www.instagram.com/danielpasqualini_/"
							target="_blank"
							rel="noopener noreferrer"
						>
							Instagram
						</a>
					</div>
				</div>
			</section>
		</main>
	</body>
</html>

<style>
	body {
		margin: 0;
		background: var(--ink);
		color: var(--cream);
	}

	.wip-page {
		min-height: 100vh;
		background:
			linear-gradient(
				90deg,
				rgba(28, 28, 27, 0.88),
				rgba(28, 28, 27, 0.52) 48%,
				rgba(28, 28, 27, 0.26)
			),
			url("/images/title-background.jpg") center center / cover no-repeat;
	}

	.wip-hero {
		min-height: 100vh;
		display: grid;
		place-items: center;
		padding: clamp(24px, 5vw, 64px);
	}

	.wip-card {
		width: min(100%, 980px);
		display: grid;
		gap: clamp(32px, 5vw, 56px);
		padding: clamp(28px, 6vw, 72px);
		border: 1px solid rgba(244, 234, 220, 0.18);
		border-radius: 42px;
		background:
			radial-gradient(circle at 86% 12%, rgba(215, 174, 129, 0.18), transparent 20rem),
			radial-gradient(circle at 10% 90%, rgba(198, 119, 79, 0.12), transparent 22rem),
			rgba(28, 28, 27, 0.58);
		backdrop-filter: blur(18px);
		box-shadow: 0 28px 90px rgba(0, 0, 0, 0.28);
	}

	.logo-wrap {
		width: min(100%, 420px);
	}

	.logo-wrap img {
		width: 100%;
		height: auto;
		display: block;
	}

	.wip-copy {
		display: grid;
		gap: 24px;
		max-width: 760px;
	}

	.wip-copy .eyebrow {
		margin: 0;
		font-size: clamp(0.9rem, 1.2vw, 1.05rem);
	}

	.wip-copy h1 {
		margin: 0;
		color: var(--sand);
		font-size: clamp(4rem, 10vw, 9.5rem);
		letter-spacing: 0.015em;
		line-height: 0.88;
		padding-left: 0.04em;
		text-shadow: 0 8px 32px rgba(0, 0, 0, 0.34);
	}

	.wip-copy p:not(.eyebrow) {
		max-width: 680px;
		margin: 0;
		color: rgba(244, 234, 220, 0.86);
		font-size: clamp(1.05rem, 1.6vw, 1.28rem);
		line-height: 1.6;
	}

	.wip-links {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
	}

	.wip-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 46px;
		padding: 12px 18px;
		border: 1px solid rgba(215, 174, 129, 0.42);
		border-radius: 999px;
		color: var(--sand);
		background: rgba(28, 28, 27, 0.42);
		font-size: 0.86rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		transition:
			background 180ms ease,
			color 180ms ease,
			border-color 180ms ease,
			transform 180ms ease;
	}

	.wip-links a:hover {
		color: var(--cream);
		border-color: rgba(215, 174, 129, 0.72);
		background: rgba(244, 234, 220, 0.08);
		transform: translateY(-2px);
	}

	@media (max-width: 850px) {
		.wip-hero {
			align-items: start;
			padding: 24px 18px;
		}

		.wip-card {
			margin-top: 24px;
			border-radius: 32px;
			padding: 26px;
		}

		.logo-wrap {
			width: min(100%, 320px);
		}

		.wip-copy h1 {
			font-size: clamp(3.5rem, 18vw, 6.8rem);
		}

		.wip-links {
			flex-direction: column;
			align-items: stretch;
		}

		.wip-links a {
			width: 100%;
		}
	}
</style>
